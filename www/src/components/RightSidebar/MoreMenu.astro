---
import * as CONFIG from '../../config';

type Props = {
	editHref: string;
};

const { editHref } = Astro.props as Props;
const showMoreSection = editHref || CONFIG.COMMUNITY_INVITE_URL;
---

{showMoreSection && (
	<>
		<h2 class="heading">More</h2>
		<ul class="more-list">
			{editHref && (
				<li>
					<a class="more-link" href={editHref} target="_blank" rel="noopener noreferrer">
						<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
						</svg>
						<span>Edit this page</span>
					</a>
				</li>
			)}
			{CONFIG.COMMUNITY_INVITE_URL && (
				<li>
					<a class="more-link" href={CONFIG.COMMUNITY_INVITE_URL} target="_blank" rel="noopener noreferrer">
						<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2Z" />
						</svg>
						<span>Join the community</span>
					</a>
				</li>
			)}
		</ul>
	</>
)}

<style>
	.more-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1px;
	}

	.more-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.35rem 0.75rem;
		font-size: 0.85rem;
		color: var(--theme-text-muted);
		text-decoration: none;
		border-radius: var(--radius);
		transition: color 120ms ease, background 120ms ease;
	}

	.more-link:hover {
		color: var(--theme-text);
		background: var(--theme-bg-hover);
		text-decoration: none;
	}

	.more-link svg {
		opacity: 0.7;
	}
</style>
