---
type Props = {
	path: string;
};
---

<footer>
	<div class="footer-inner">
		<div class="footer-left">
			<svg class="footer-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
				<path d="M13 2L4.5 13.5h6L11 22l8.5-11.5h-6L13 2Z" fill="currentColor" />
			</svg>
			<span>ElectroDB</span>
		</div>
		<div class="footer-links">
			<a href="https://github.com/tywalch/electrodb" target="_blank" rel="noopener noreferrer">GitHub</a>
			<a href="https://electrodb.fun" target="_blank" rel="noopener noreferrer">Playground</a>
			<a href="https://github.com/tywalch/electrodb/discussions" target="_blank" rel="noopener noreferrer">Discussions</a>
		</div>
		<div class="footer-right">
			Built by <a href="http://tinkertamper.com" target="_blank" rel="noopener noreferrer">tinkertamper</a>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: auto;
		padding: 2.5rem 1.5rem;
		border-top: 1px solid var(--theme-border);
		font-size: 0.85rem;
		color: var(--theme-text-muted);
	}

	.footer-inner {
		max-width: 88rem;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.footer-left {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--theme-text);
		font-weight: 600;
		font-size: 0.9rem;
		letter-spacing: -0.01em;
	}

	.footer-icon {
		width: 16px;
		height: 16px;
		color: var(--theme-accent);
	}

	.footer-links {
		display: inline-flex;
		align-items: center;
		gap: 1.25rem;
		flex-wrap: wrap;
	}

	.footer-links a {
		color: var(--theme-text-muted);
		text-decoration: none;
		transition: color 120ms ease;
	}

	.footer-links a:hover {
		color: var(--theme-text);
	}

	.footer-right a {
		color: var(--theme-text-light);
		text-decoration: none;
	}

	.footer-right a:hover {
		color: var(--theme-text);
		text-decoration: underline;
	}
</style>
